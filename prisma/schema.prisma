// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  groupMembers  GroupMember[]
  paidExpenses  Expense[]       @relation("Payer")
  splits        ExpenseSplit[]
  sentSettlements     Settlement[] @relation("Payer")
  receivedSettlements Settlement[] @relation("Receiver")
  activities    Activity[]
  fridgeItems   FridgeItem[]
  familyMembers FamilyMember[]
  transactions  Transaction[]

  // CalendarEase
  calendarGroupsCreated CalendarGroup[]  @relation("CalendarGroupCreator")
  calendarMemberships   CalendarMember[]
  calendarEventsCreated CalendarEvent[]  @relation("CalendarEventCreator")
  petsCreated           Pet[]            @relation("PetCreator")
  petLogsLogged         PetLog[]         @relation("PetLogLogger")
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  category    GroupCategory @default(OTHER)
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String

  // Relations
  members     GroupMember[]
  expenses    Expense[]
  settlements Settlement[]
  activities  Activity[]
}

enum GroupCategory {
  HOME
  TRIP
  FOOD
  WORK
  OTHER
}

model GroupMember {
  id       String   @id @default(cuid())
  role     MemberRole @default(MEMBER)
  joinedAt DateTime @default(now())

  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

enum MemberRole {
  ADMIN
  MEMBER
}

model Expense {
  id          String      @id @default(cuid())
  title       String
  description String?
  amount      Float
  currency    String      @default("USD")
  category    ExpenseCategory @default(OTHER)
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  paidById String
  groupId  String

  paidBy User  @relation("Payer", fields: [paidById], references: [id])
  group  Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  splits ExpenseSplit[]
}

enum ExpenseCategory {
  FOOD
  TRANSPORT
  ACCOMMODATION
  ENTERTAINMENT
  UTILITIES
  SHOPPING
  HEALTH
  OTHER
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  amount    Float
  settled   Boolean @default(false)
  settledAt DateTime?

  expenseId String
  userId    String

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
}

model Settlement {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("USD")
  note      String?
  createdAt DateTime @default(now())

  payerId    String
  receiverId String
  groupId    String

  payer    User  @relation("Payer",    fields: [payerId],    references: [id])
  receiver User  @relation("Receiver", fields: [receiverId], references: [id])
  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}
model Activity {
  id        String   @id @default(cuid())
  type      ActivityType
  message   String
  createdAt DateTime @default(now())

  userId  String
  groupId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

enum ActivityType {
  EXPENSE_ADDED
  EXPENSE_DELETED
  SETTLEMENT
  MEMBER_JOINED
}
model FridgeItem {
  id        String    @id @default(cuid())
  name      String
  quantity  Float
  unit      String
  price     Float?
  expiresAt DateTime?
  used      Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  addedById  String
  familyId   String

  addedBy    User        @relation(fields: [addedById], references: [id], onDelete: Cascade)
  family     FamilyGroup @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model FamilyGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  createdById String

  members     FamilyMember[]
  fridgeItems FridgeItem[]
}

model FamilyMember {
  id       String   @id @default(cuid())
  role     MemberRole @default(MEMBER)
  joinedAt DateTime @default(now())

  userId   String
  familyId String

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  family FamilyGroup @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([userId, familyId])
}

enum TransactionCategory {
  TRANSPORT
  FOOD
  MEDICAL
  ENTERTAINMENT
  FASHION_BEAUTY
  HOUSING
  DAILY
  OTHER
  EDUCATION
  FINANCE
}

model Transaction {
  id          String              @id @default(cuid())
  amount      Float
  category    TransactionCategory @default(OTHER)
  description String?
  date        DateTime            @default(now())
  source      String?
  createdAt   DateTime            @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── CalendarEase ─────────────────────────────────────────────────────────────

enum CalendarMemberRole {
  OWNER
  MEMBER
}

enum PetLogType {
  FEED
  POOP
  WATER
  BATH
  MEDICINE
  VET
  OTHER
}

model CalendarGroup {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  createdById String

  createdBy User             @relation("CalendarGroupCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members   CalendarMember[]
  events    CalendarEvent[]
  pets      Pet[]
}

model CalendarMember {
  id        String             @id @default(cuid())
  role      CalendarMemberRole @default(MEMBER)
  createdAt DateTime           @default(now())

  userId  String
  groupId String

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group CalendarGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model CalendarEvent {
  id           String   @id @default(cuid())
  title        String
  description  String?
  location     String?
  startAt      DateTime
  endAt        DateTime
  isAllDay     Boolean  @default(false)
  color        String   @default("#8b5cf6")
  notifyBefore Int      @default(15)
  isFromPetLog Boolean  @default(false)
  createdAt    DateTime @default(now())

  groupId     String
  createdById String

  group     CalendarGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User          @relation("CalendarEventCreator", fields: [createdById], references: [id], onDelete: Cascade)
}

model Pet {
  id        String    @id @default(cuid())
  name      String
  type      String
  birthday  DateTime?
  photoUrl  String?
  createdAt DateTime  @default(now())

  groupId     String
  createdById String

  group     CalendarGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy User          @relation("PetCreator", fields: [createdById], references: [id], onDelete: Cascade)
  logs      PetLog[]
}

model PetLog {
  id       String     @id @default(cuid())
  type     PetLogType @default(FEED)
  note     String?
  loggedAt DateTime   @default(now())

  petId       String
  loggedById  String

  pet      Pet  @relation(fields: [petId], references: [id], onDelete: Cascade)
  loggedBy User @relation("PetLogLogger", fields: [loggedById], references: [id], onDelete: Cascade)
}